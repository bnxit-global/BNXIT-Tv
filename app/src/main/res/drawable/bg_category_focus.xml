<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state (D-pad selection) -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <!-- Premium vibrant blue-purple gradient for TV focus -->
            <gradient
                android:startColor="#FF00E5FF"
                android:endColor="#FF2979FF"
                android:angle="0" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    
    <!-- Active/Selected state (currently playing category) -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#26FFFFFF" />
            <stroke android:width="1dp" android:color="#4DFFFFFF" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
