<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/focus_glow" />
            <stroke android:width="2dp" android:color="@color/focus_border" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/item_selected" />
            <stroke android:width="1dp" android:color="@color/focus_blue" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/item_default" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
