<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- TV-first dark theme: no action bar, fullscreen, no animations -->
    <style name="Theme.BNXITTv" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorPrimary">@color/focus_blue</item>
        <item name="colorPrimaryDark">@color/bg_primary</item>
        <item name="colorAccent">@color/focus_blue</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <!-- Disable default animations for performance -->
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- Styled alert dialog for TV style track/quality selection -->
    <style name="TvDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_panel</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorAccent">@color/focus_blue</item>
    </style>
</resources>